class Solution {
    public int maxAbsoluteSum(int[] nums) {
        
    int sum=0;
    int maxSum=0;
    int minSum=0;
    for(int num : nums){
        sum+=num;
        if(maxSum<sum){
            maxSum=sum;
        }
        if(minSum>sum){
            minSum=sum;
        }
    }
    return Math.abs(maxSum-minSum);
    }
}
