class Solution {
    int[][][] dp;
    int m, n;

    public int maximumAmount(int[][] coins) {
        m = coins.length;
        n = coins[0].length;
        dp = new int[m][n][3];

        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                for (int k = 0; k < 3; k++) {
                    dp[i][j][k] = Integer.MIN_VALUE;
                }
            }
        }

        return dfs(0, 0, 2, coins);
    }

    private int dfs(int i, int j, int k, int[][] coins) {
        if (i >= m || j >= n) return Integer.MIN_VALUE / 2;

        if (i == m - 1 && j == n - 1) {
            if (k > 0) return Math.max(0, coins[i][j]);
            return coins[i][j];
        }

        if (dp[i][j][k] != Integer.MIN_VALUE) return dp[i][j][k];

        int res = coins[i][j] + Math.max(
                dfs(i + 1, j, k, coins),
                dfs(i, j + 1, k, coins)
        );

        if (coins[i][j] < 0 && k > 0) {
            res = Math.max(res, Math.max(
                    dfs(i + 1, j, k - 1, coins),
                    dfs(i, j + 1, k - 1, coins)
            ));
        }

        return dp[i][j][k] = res;
    }
}
