class Solution {
    public String generateString(String str1, String str2) {
        int n = str1.length();
        int m = str2.length();
        int size = n + m - 1;

        char[] ans = new char[size];
        boolean[] fixed = new boolean[size];

        for (int i = 0; i < size; i++) {
            ans[i] = '?';
        }

        for (int i = 0; i < n; i++) {
            if (str1.charAt(i) == 'T') {
                for (int j = 0; j < m; j++) {
                    int pos = i + j;
                    if (ans[pos] == '?' || ans[pos] == str2.charAt(j)) {
                        ans[pos] = str2.charAt(j);
                        fixed[pos] = true;
                    } else {
                        return "";
                    }
                }
            }
        }

        for (int i = 0; i < size; i++) {
            if (ans[i] == '?') {
                ans[i] = 'a';
            }
        }

        for (int i = 0; i < n; i++) {
            if (str1.charAt(i) == 'F') {
                if (matches(ans, i, str2)) {
                    boolean changed = false;

                    for (int j = m - 1; j >= 0; j--) {
                        int pos = i + j;

                        if (fixed[pos]) continue;

                        for (char c = 'a'; c <= 'z'; c++) {
                            if (c != str2.charAt(j)) {
                                char old = ans[pos];
                                ans[pos] = c;

                                if (!matches(ans, i, str2)) {
                                    changed = true;
                                    break;
                                }

                                ans[pos] = old;
                            }
                        }

                        if (changed) break;
                    }

                    if (!changed) return "";
                }
            }
        }

        return new String(ans);
    }

    private boolean matches(char[] ans, int start, String str2) {
        for (int i = 0; i < str2.length(); i++) {
            if (ans[start + i] != str2.charAt(i)) return false;
        }
        return true;
    }
}
