class Solution {
    public int[] nextGreaterElement(int[] nums1, int[] nums2) {
        int[] ans = new int[nums1.length];

        for (int i = 0; i < nums1.length; i++) {
            Stack<Integer> st = new Stack<>();
            int next = -1;

            for (int j = nums2.length - 1; j >= 0; j--) {

                while (!st.isEmpty() && st.peek() <= nums2[j]) {
                    st.pop();
                }

                if (nums2[j] == nums1[i]) {
                    if (st.isEmpty()) {
                        next = -1;
                    } else {
                        next = st.peek();
                    }
                    break;
                }

                st.push(nums2[j]);
            }

            ans[i] = next;
        }

        return ans;
    }
}
