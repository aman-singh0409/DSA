class Solution {
    public int numSubarrayProductLessThanK(int[] nums, int k) {
        if(k<=1){
            return 0;
        }
        int pro=1;
        int left=0;
        int c=0;
        for(int i=0;i<nums.length;i++){
            pro*=nums[i];
            while(pro>=k){
                pro/=nums[left];
                left++;
            }
            c=i-left+1;
        }
        return c;
    }
}
